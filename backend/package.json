    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.0",
    "drizzle-orm": "^0.41.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "postgres": "^3.4.7",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
