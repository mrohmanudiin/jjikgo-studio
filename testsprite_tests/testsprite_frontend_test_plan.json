  {
    "id": "TC010",
    "title": "Invalid or expired QR returns Not Found/Invalid QR error",
    "description": "Verifies the system displays an error when staff scans/enters an invalid or expired QR code.",
    "category": "Queue System (Staff)",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /api/branches"
      },
      {
        "type": "action",
        "description": "Click on \"Search by QR\""
      },
      {
        "type": "assertion",
        "description": "Verify element \"QR code input\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"INVALID-QR-$$$$\" into \"QR code input\""
      },
      {
        "type": "action",
        "description": "Press Enter"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Invalid QR\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Contact staff\" is visible"
      }
    ]
  },
