[
  {
    "id": "TC001",
    "title": "Create a complete transaction and pay successfully (happy path)",
    "description": "Verifies a cashier can complete a transaction with all options and see a payment confirmation with a unique invoice number.",
    "category": "Cashier POS - Transaction Creation & Payment",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to the Cashier App home page (the main Cashier POS entry screen)."
      },
      {
        "type": "action",
        "description": "Click on \"Start new transaction\"."
      },
      {
        "type": "action",
        "description": "Type \"Test Customer\" into the customer name field."
      },
      {
        "type": "action",
        "description": "Select a theme from the theme selector."
      },
      {
        "type": "action",
        "description": "Select a package from the package selector."
      },
      {
        "type": "action",
        "description": "Click on \"Pay\"."
      },
      {
        "type": "assertion",
        "description": "Verify a payment confirmation message is visible."
      },
      {
        "type": "assertion",
        "description": "Verify text \"Invoice\" is visible."
      }
    ]
  },
