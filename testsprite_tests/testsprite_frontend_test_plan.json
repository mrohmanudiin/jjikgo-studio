  {
    "id": "TC012",
    "title": "Open a shift with starting cash and verify active status",
    "description": "Verifies staff can open a shift by entering starting cash and the shift becomes active.",
    "category": "Shift Handling & Expense Tracking (Staff)",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /api/auth/login"
      },
      {
        "type": "assertion",
        "description": "Verify text \"User Login\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Shift\" is visible"
      },
      {
        "type": "action",
        "description": "Click the \"Open Shift\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Starting cash\" is visible"
      }
    ]
  },
