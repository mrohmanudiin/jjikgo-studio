{
    "name": "jjikgo-photobooth-workspace",
    "private": true,
    "engines": {
        "node": ">=18.0.0"
    },
    "workspaces": [
        "apps/*",
        "backend"
    ],
    "scripts": {
        "dev:cashier": "npm run dev --workspace=apps/cashier-app",
        "dev:staff": "npm run dev --workspace=apps/staff-app",
        "dev:admin": "npm run dev --workspace=apps/admin-dashboard",
        "dev:backend": "npm run dev --workspace=backend",
        "build:cashier": "npm run build --workspace=apps/cashier-app",
        "build:staff": "npm run build --workspace=apps/staff-app",
        "build:admin": "npm run build --workspace=apps/admin-dashboard",
        "build:backend": "cd backend && npm install && npm run db:setup",
        "start:cashier": "serve -s apps/cashier-app/dist -p ${PORT:-3000}",
        "start:staff": "serve -s apps/staff-app/dist -p ${PORT:-3000}",
        "start:admin": "serve -s apps/admin-dashboard/dist -p ${PORT:-3000}",
        "start:backend": "npm run start --workspace=backend",
        "start": "npm run start:backend",
        "build": "npm run build:admin"
    },
    "dependencies": {
        "serve": "^14.2.6"
    }
}
